# ============================================================
# Academia J Rubio — Variables de entorno
# Copia este archivo a .env y completa los valores
# ============================================================

# --- App ---
NODE_ENV=development
APP_NAME="Academia J Rubio"
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (Neon Postgres) ---
# https://neon.tech — free tier
DATABASE_URL="postgresql://user:password@host.neon.tech/academia_jrubio?sslmode=require"

# --- Redis (Upstash) ---
REDIS_URL="redis://default:password@host.upstash.io:6379"

# --- Auth.js / NextAuth v5 ---
# Genera con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-en-produccion"
AUTH_URL=http://localhost:3000
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Email (Resend) ---
RESEND_API_KEY=""
EMAIL_FROM="Academia J Rubio <no-reply@academia-jrubio.com>"

# --- Storage: Nextcloud (WebDAV) ---
NEXTCLOUD_URL="https://tu-nextcloud.example.com"
NEXTCLOUD_USER="usuario-app"
# Crear un "App Password" desde Configuración > Seguridad de Nextcloud
NEXTCLOUD_APP_PASSWORD=""
NEXTCLOUD_BASE_PATH="/AcademiaJRubio/files"

# --- Stripe ---
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

# --- Telegram (Fase 2) ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# --- IA (Fase 2) ---
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- Minimax IA (chat de búsqueda) ---
# Token del plan de Minimax. Si está vacío, el chat usa búsqueda local.
MINIMAX_API_KEY=""
MINIMAX_ENDPOINT="https://api.minimaxi.chat/v1/text/chatcompletion_v2"

# --- Observabilidad ---
SENTRY_DSN=""
POSTHOG_KEY=""
