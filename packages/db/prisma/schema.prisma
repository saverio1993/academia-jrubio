// ============================================================
// Academia J Rubio — Schema inicial (Fase 0)
// Cubre: usuarios, planes, suscripciones, pagos, archivos, audit log
// Telegram, IA y cursos se agregan en Fase 2/3
// ============================================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- USERS ----------

enum UserRole {
  USER
  MODERATOR
  ADMIN
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  username    String?  @unique
  name        String?
  phone       String?
  country     String?
  role        UserRole @default(USER)

  // OAuth (campo estándar requerido por @auth/prisma-adapter)
  emailVerified   DateTime?
  image           String?
  telegramId      String?  @unique
  telegramHandle  String?

  passwordHash String?
  reputation   Int      @default(0)

  subscriptions  Subscription[]
  payments       Payment[]
  downloads      Download[]
  auditLogs      AuditLog[]
  accounts       Account[]
  sessions       Session[]
  favorites      Favorite[]
  notifications  Notification[]
  fileReports    FileReport[]

  enrollments    Enrollment[]
  lessonProgress LessonProgress[]
  certificates   Certificate[]
  quizAttempts   QuizAttempt[]
  lessonComments LessonComment[]
  oneTimeLinks   OneTimeLink[]

  posts         Post[]
  postComments  PostComment[]
  postReactions PostReaction[]
  savedPosts    SavedPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

// NextAuth tables (compat con @auth/prisma-adapter)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- PLANS & SUBSCRIPTIONS ----------

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
  LIFETIME
}

model Plan {
  id           String       @id @default(cuid())
  slug         String       @unique
  name         String
  description  String?
  priceCents   Int
  currency     String       @default("USD")
  billingCycle BillingCycle
  features     Json         @default("[]")
  isActive     Boolean      @default(true)
  sortOrder    Int          @default(0)

  // Telegram (Fase 2)
  telegramGroupId String?
  telegramInviteLink String?

  // Stripe
  stripeProductId String? @unique
  stripePriceId   String? @unique

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  SUSPENDED
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  planId    String
  status    SubscriptionStatus @default(ACTIVE)

  startedAt DateTime  @default(now())
  expiresAt DateTime?
  canceledAt DateTime?

  // Stripe (cuando aplique)
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([expiresAt])
}

// ---------- PAYMENTS ----------

enum PaymentProvider {
  STRIPE
  BINANCE_PAY
  PAYPAL
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  AWAITING_APPROVAL // pago manual con comprobante
  REJECTED
}

model Payment {
  id         String          @id @default(cuid())
  userId     String
  amountCents Int
  currency   String          @default("USD")
  provider   PaymentProvider
  status     PaymentStatus   @default(PENDING)

  providerRef String? @unique
  proofUrl    String? // para pagos manuales
  notes       String?

  approvedById String?
  approvedAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

// ---------- FILES (biblioteca) ----------

model FileItem {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  brand       String   // Samsung, Xiaomi, etc
  model       String?
  category    String   // firmware, drivers, herramientas, etc
  subcategory String?
  version     String?
  sizeBytes   BigInt?
  mimeType    String?

  // Storage (Nextcloud por ahora)
  storageProvider String @default("nextcloud")
  storageKey      String // path dentro de Nextcloud

  isPremium       Boolean @default(true)
  downloadsCount  Int     @default(0)
  tags            String[] @default([])

  downloads     Download[]
  oneTimeLinks  OneTimeLink[]
  favorites     Favorite[]
  notifications Notification[]
  fileReports   FileReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand, category])
  @@index([tags])
}

// ---------- REPORTES DE ARCHIVOS ----------

model FileReport {
  id         String    @id @default(cuid())
  userId     String
  fileItemId String
  reason     String    // "danado", "no_compatible", "enlace_roto", "version_incorrecta", "otro"
  comment    String?
  status     String    @default("pending") // "pending", "resolved", "dismissed"
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileItem FileItem @relation(fields: [fileItemId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([fileItemId])
}

// ---------- FAVORITOS ----------

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  fileItemId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileItem FileItem @relation(fields: [fileItemId], references: [id], onDelete: Cascade)

  @@unique([userId, fileItemId])
  @@index([userId])
}

// ---------- NOTIFICACIONES ----------

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String
  fileItemId String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileItem FileItem? @relation(fields: [fileItemId], references: [id], onDelete: SetNull)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Download {
  id     String @id @default(cuid())
  userId String
  fileId String
  ip     String?
  userAgent String?

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file FileItem @relation(fields: [fileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([fileId])
}

// ---------- AUDIT ----------

model AuditLog {
  id       String  @id @default(cuid())
  actorId  String?
  action   String  // ej: "payment.approved", "user.role.changed"
  target   String? // ej: "user:xyz", "payment:abc"
  metadata Json    @default("{}")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([actorId])
}

// ---------- CURSOS (Academia · Fase 3) ----------

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  VIDEO
  PDF
  TEXT
}

model Course {
  id          String      @id @default(cuid())
  slug        String      @unique
  title       String
  description String?     @db.Text
  coverImage  String?
  level       CourseLevel @default(BEGINNER)
  isPublished Boolean     @default(false)
  isPremium   Boolean     @default(true)
  sortOrder   Int         @default(0)

  lessons      Lesson[]
  enrollments  Enrollment[]
  certificates Certificate[]
  quiz         Quiz?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isPublished, sortOrder])
}

model Lesson {
  id          String     @id @default(cuid())
  courseId    String
  title       String
  description String?    @db.Text
  type        LessonType @default(VIDEO)

  videoUrl    String? // URL de video (YouTube/Vimeo/embed)
  storageKey  String? // PDF u otro recurso en Nextcloud
  contentText String? @db.Text // contenido para lecciones tipo TEXT

  durationSec   Int?
  sortOrder     Int     @default(0)
  isFreePreview Boolean @default(false)

  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress LessonProgress[]
  comments LessonComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId, sortOrder])
}

// ---------- INSCRIPCIONES, PROGRESO Y CERTIFICADOS (Fase 3) ----------

model Enrollment {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Certificate {
  id       String   @id @default(cuid())
  userId   String
  courseId String
  code     String   @unique
  issuedAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// ---------- EVALUACIONES (Fase 3) ----------

model Quiz {
  id           String @id @default(cuid())
  courseId     String @unique
  title        String @default("Evaluación final")
  passingScore Int    @default(70) // porcentaje mínimo para aprobar

  course    Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuizQuestion {
  id           String @id @default(cuid())
  quizId       String
  text         String @db.Text
  options      Json   @default("[]") // string[]
  correctIndex Int    @default(0)
  sortOrder    Int    @default(0)

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@index([quizId, sortOrder])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  userId    String
  score     Int // porcentaje 0-100
  passed    Boolean
  createdAt DateTime @default(now())

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId, userId])
}

// ---------- COMUNIDAD (Fase 3) ----------

model LessonComment {
  id        String   @id @default(cuid())
  lessonId  String
  userId    String
  body      String   @db.Text
  parentId  String?
  createdAt DateTime @default(now())

  lesson  Lesson          @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  LessonComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies LessonComment[] @relation("CommentReplies")

  @@index([lessonId, createdAt])
}

// ---------- LINKS DE DESCARGA DE UN SOLO USO ----------

model OneTimeLink {
  id          String    @id @default(cuid())
  token       String    @unique @default(uuid())
  fileItemId  String
  createdById String
  note        String?   // para quién es el link (opcional)
  expiresAt   DateTime
  usedAt      DateTime?
  usedByIp    String?

  fileItem  FileItem @relation(fields: [fileItemId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([token])
  @@index([fileItemId])
}

// ---------- CUPONES DE DESCUENTO ----------

model Coupon {
  id             String    @id @default(cuid())
  code           String    @unique
  description    String?
  type           String    // "PERCENT" | "FIXED"
  value          Float     // % (0-100) for PERCENT, cents for FIXED
  maxUses        Int?      // null = unlimited
  uses           Int       @default(0)
  active         Boolean   @default(true)
  expiresAt      DateTime?
  stripeCouponId String?
  createdAt      DateTime  @default(now())

  @@index([code, active])
}

// ---------- COMUNIDAD FORO ----------

enum PostStatus {
  DRAFT
  PUBLISHED
  CLOSED
}

model Post {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique
  content   String     @db.Text
  category  String     // 'frp' | 'imei' | 'flash' | 'unlock' | 'herramientas' | 'general'
  status    PostStatus @default(PUBLISHED)
  pinned    Boolean    @default(false)
  views     Int        @default(0)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    PostComment[]
  reactions   PostReaction[]
  attachments PostAttachment[]
  savedBy     SavedPost[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, pinned, createdAt])
  @@index([category, status])
  @@index([authorId])
}

model SavedPost {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
}

model PostComment {
  id        String        @id @default(cuid())
  content   String        @db.Text
  authorId  String
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  postId    String
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId   String?
  parent     PostComment?  @relation("PostCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies    PostComment[] @relation("PostCommentReplies")
  isSolution Boolean       @default(false)
  createdAt  DateTime      @default(now())

  @@index([postId, createdAt])
  @@index([parentId])
}

model PostReaction {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  type      String   // 'like' | 'heart' | 'fire'
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId, type])
  @@index([postId])
}

model PostAttachment {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String?
  sizeBytes  BigInt?
  storageKey String
  publicUrl  String
  createdAt  DateTime @default(now())

  @@index([postId])
}

// ---------- IA CONFIGURACIÓN (Fase 2) ----------

model AIConfig {
  id           String   @id @default("default")
  provider     String   @default("minimax")
  apiKey       String   @default("")
  endpoint     String   @default("https://api.minimax.io/v1")
  model        String   @default("MiniMax-M2.7-highspeed")
  systemPrompt String   @default("Eres el asistente de búsqueda de la Academia J Rubio. SOLO puedes ayudar a buscar archivos en la biblioteca. NO tienes acceso a admin ni a funciones de modificación. Responde en español, breve y amigable.") @db.Text
  enabled      Boolean  @default(true)
  maxTokens    Int      @default(500)
  temperature  Float    @default(0.3)
  rateLimit    Int      @default(30)
  updatedBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
